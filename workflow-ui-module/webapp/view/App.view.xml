<mvc:View controllerName="bpaaudit.workflowuimodule.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:uxap="sap.uxap"
    xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    displayBlock="true">
 
    <uxap:ObjectPageLayout id="objectPageLayout" showTitleInHeaderContent="true" showFooter="false">
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle id="_IDGenObjectPageDynamicHeaderTitle1">
                <uxap:expandedHeading>
                    <!-- Binding Header to Customer Name -->
                    <Title id="_IDGenTitle1" text="{context>/name}"/>
                </uxap:expandedHeading>
            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>
 
        <uxap:sections>
            <uxap:ObjectPageSection id="customerSection" titleUppercase="false">
                <uxap:subSections>
                    <!-- CUSTOMER DETAILS -->
                    <uxap:ObjectPageSubSection id="_IDGenObjectPageSubSection" title="Customer Details" titleUppercase="false">
                        <form:SimpleForm id="_IDGenSimpleForm" editable="false" layout="ResponsiveGridLayout">
                            <form:content>
                                <Label id="_IDGenLabel" text="Customer ID"/>
                                <Text id="_IDGenText" text="{context>/customerID}"/>
                                <Label id="_IDGenLabel1" text="Customer Name"/>
                                <Text id="_IDGenText1" text="{context>/name}"/>
                                <Label id="_IDGenLabel2" text="Email"/>
                                <Text id="_IDGenText2" text="{context>/email}"/>
                                <Label id="_IDGenLabel3" text="Phone"/>
                                <Text id="_IDGenText3" text="{context>/phone}"/>
                            </form:content>
                        </form:SimpleForm>
                    </uxap:ObjectPageSubSection>
 
                    <!-- PRODUCT TABLE: Binding to the composition array -->
                    <uxap:ObjectPageSubSection id="_IDGenObjectPageSubSection1" title="Product Details" titleUppercase="false">
                        <Table id="productTable" items="{context>/customerToproducts}">
                            <columns>
                                <Column id="_IDGenColumn"><Text id="_IDGenText4" text="Product ID"/></Column>
                                <Column id="_IDGenColumn1"><Text id="_IDGenText5" text="Product Name"/></Column>
                                <Column id="_IDGenColumn2"><Text id="_IDGenText6" text="Price"/></Column>
                                <Column id="_IDGenColumn3"><Text id="_IDGenText7" text="Category"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem id="_IDGenColumnListItem">
                                    <cells>
                                        <!-- Relative paths inside the array -->
                                        <Text id="_IDGenText8" text="{context>productID}"/>
                                        <Text id="_IDGenText9" text="{context>productName}"/>
                                        <Text id="_IDGenText10" text="{context>price}"/>
                                        <Text id="_IDGenText11" text="{context>category}"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </uxap:ObjectPageSubSection>
 
                    <!-- ORDER TABLE: Binding to the composition array -->
                    <uxap:ObjectPageSubSection id="_IDGenObjectPageSubSection2" title="Order Details" titleUppercase="false">
                        <Table id="orderTable" items="{context>/customerToorder}">
                            <columns>
                                <Column id="_IDGenColumn4"><Text id="_IDGenText12" text="Order ID"/></Column>
                                <Column id="_IDGenColumn5"><Text id="_IDGenText13" text="Order Date"/></Column>
                                <Column id="_IDGenColumn6"><Text id="_IDGenText14" text="Quantity"/></Column>
                                <Column id="_IDGenColumn7"><Text id="_IDGenText15" text="Total Amount"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem id="_IDGenColumnListItem1">
                                    <cells>
                                        <Text id="_IDGenText16" text="{context>orderID}"/>
                                        <Text id="_IDGenText17" text="{context>orderDate}"/>
                                        <Text id="_IDGenText18" text="{context>quantity}"/>
                                        <Text id="_IDGenText19" text="{context>totalAmount}"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
        </uxap:sections>
    </uxap:ObjectPageLayout>
</mvc:View>
