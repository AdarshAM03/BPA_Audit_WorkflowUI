<mvc:View controllerName="bpaaudit.workflowuimodule.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:uxap="sap.uxap"
    xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    displayBlock="true">
 
    <!-- ================= OBJECT PAGE LAYOUT ================= -->
 
    <uxap:ObjectPageLayout
        id="objectPageLayout"
        showTitleInHeaderContent="true"
        showFooter="false">
 
        <!-- ================= HEADER TITLE ================= -->
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle id="_IDGenObjectPageDynamicHeaderTitle1">
                <uxap:expandedHeading>
                </uxap:expandedHeading>
            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>
 
 
        <!-- ================= SECTIONS ================= -->
 
        <uxap:sections>
 
            <uxap:ObjectPageSection
                id="customerSection"
               
                titleUppercase="false">
 
                <uxap:subSections>
 
                    <!-- ================= CUSTOMER DETAILS ================= -->
                    <uxap:ObjectPageSubSection id="_IDGenObjectPageSubSection"
                        title="Customer Details"
                        titleUppercase="false">
 
                        <form:SimpleForm id="_IDGenSimpleForm"
                            editable="false"
                            layout="ResponsiveGridLayout"
                            singleContainerFullSize="false">
 
                            <form:content>
 
                                <Label id="_IDGenLabel" text="Customer ID"/>
                                <Input id="_IDGenInput" value="{context>/customerID}" editable="false"/>
 
                                <Label id="_IDGenLabel1" text="Customer Name"/>
                                <Input id="_IDGenInput1" value="{context>/name}" editable="false"/>
 
                                <Label id="_IDGenLabel2" text="Email"/>
                                <Input id="_IDGenInput2" value="{context>/email}" editable="false"/>
 
                                <Label id="_IDGenLabel3" text="Phone"/>
                                <Input id="_IDGenInput3" value="{context>/phone}" editable="false"/>
 
                            </form:content>
 
                        </form:SimpleForm>
 
                    </uxap:ObjectPageSubSection>
 
 
                    <!-- ================= PRODUCT TABLE ================= -->
                    <uxap:ObjectPageSubSection id="_IDGenObjectPageSubSection1"
                        title="Product Details"
                        titleUppercase="false">
 
                        <ScrollContainer id="_IDGenScrollContainer"
                            horizontal="true"
                            vertical="false"
                            width="100%">
 
                            <Table
                                id="productTable"
                                sticky="ColumnHeaders">
 
                                <columns>
                                    <Column id="_IDGenColumn" width="12rem">
                                        <Text id="_IDGenText" text="Product ID"/>
                                    </Column>
                                    <Column id="_IDGenColumn1" width="16rem">
                                        <Text id="_IDGenText1" text="Product Name"/>
                                    </Column>
                                    <Column id="_IDGenColumn2" width="12rem">
                                        <Text id="_IDGenText2" text="Price"/>
                                    </Column>
                                    <Column id="_IDGenColumn3" width="14rem">
                                        <Text id="_IDGenText3" text="Category"/>
                                    </Column>
                                </columns>
 
                                <items>
                                    <ColumnListItem id="_IDGenColumnListItem">
                                        <cells>
                                            <Text id="_IDGenText4" text="{context>/productID}"/>
                                            <Text id="_IDGenText5" text="{context>/productName}"/>
                                            <Text id="_IDGenText6" text="{context>/price}"/>
                                            <Text id="_IDGenText7" text="{context>/category}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
 
                            </Table>
 
                        </ScrollContainer>
 
                    </uxap:ObjectPageSubSection>
 
 
                    <!-- ================= ORDER TABLE ================= -->
                    <uxap:ObjectPageSubSection id="_IDGenObjectPageSubSection2"
                        title="Order Details"
                        titleUppercase="false">
 
                        <ScrollContainer id="_IDGenScrollContainer1"
                            horizontal="true"
                            vertical="false"
                            width="100%">
 
                            <Table
                                id="orderTable"
                                sticky="ColumnHeaders">
 
                                <columns>
                                    <Column id="_IDGenColumn4" width="10rem">
                                        <Text id="_IDGenText8" text="Order ID"/>
                                    </Column>
                                    <Column id="_IDGenColumn5" width="14rem">
                                        <Text id="_IDGenText9" text="Order Date"/>
                                    </Column>
                                    <Column id="_IDGenColumn6" width="10rem">
                                        <Text id="_IDGenText10" text="Quantity"/>
                                    </Column>
                                    <Column id="_IDGenColumn7" width="14rem">
                                        <Text id="_IDGenText11" text="Total Amount"/>
                                    </Column>
                                </columns>
 
                                <items>
                                    <ColumnListItem id="_IDGenColumnListItem1">
                                        <cells>
                                            <Text id="_IDGenText12" text="{context>/orderID}"/>
                                            <Text id="_IDGenText13" text="{context>/orderDate}"/>
                                            <Text id="_IDGenText14" text="{context>/quantity}"/>
                                            <Text id="_IDGenText15" text="{context>/totalAmount}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
 
                            </Table>
 
                        </ScrollContainer>
 
                    </uxap:ObjectPageSubSection>
 
 
                   
 
                </uxap:subSections>
 
            </uxap:ObjectPageSection>
 
        </uxap:sections>
 
    </uxap:ObjectPageLayout>
 
</mvc:View>  
 